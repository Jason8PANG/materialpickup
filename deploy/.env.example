# ============================================
# 物料领取看板系统 - 环境变量配置模板
# ============================================
# 使用方式:
#   1. 复制此文件为 .env 并修改配置
#   2. 或在 systemd 服务中通过 Environment= 设置

# ---------- 密钥 ----------
# Flask 应用密钥 (必填，用于 Session 加密)
SECRET_KEY=your-random-secret-key-here

# ---------- MySQL 数据库 ----------
MYSQL_HOST=10.0.6.86
MYSQL_PORT=33306
MYSQL_USER=powerbi
MYSQL_PASSWORD=your-database-password
MYSQL_DB=materialpickup

# ---------- LDAP 认证 (可选) ----------
LDAP_SERVER=ldap://10.0.0.1:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_DOMAIN=EXAMPLE

# ---------- SMTP 邮件 (可选，用于邮件审批通知) ----------
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
MAIL_FROM=kanban@example.com
MAIL_FROM_NAME=物料领取看板系统

# ---------- 系统配置 ----------
# 系统外部访问地址 (用于邮件审批链接生成)
BASE_URL=http://10.0.6.134:5000
